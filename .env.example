# AI Study Coach — Environment Variables
# Copy to .env and fill in your values

# Quiz App API (your Spring Boot backend)
COACH_QUIZ_API_URL=http://localhost:8080

# ─── Primary LLM: External API ───────────────────────────
# Pick a provider and add your API key.
#
# Option 1: Groq (free tier — fast, recommended)
#   Get a key at: https://console.groq.com
COACH_EXTERNAL_LLM_PROVIDER=groq
COACH_EXTERNAL_LLM_API_KEY=
COACH_EXTERNAL_LLM_MODEL=llama-3.1-8b-instant

# Option 2: Google AI Studio (free tier — Gemini)
#   Get a key at: https://aistudio.google.com
# COACH_EXTERNAL_LLM_PROVIDER=google
# COACH_EXTERNAL_LLM_API_KEY=
# COACH_EXTERNAL_LLM_MODEL=gemini-2.0-flash

# ─── Fallback LLM: Ollama (optional) ─────────────────────
# Only used if the external API key is not set.
# Requires Ollama running locally: https://ollama.com
COACH_OLLAMA_URL=http://localhost:11434
COACH_OLLAMA_MODEL=phi3:mini

# CORS (your frontend URL)
COACH_CORS_ORIGINS=["http://localhost:3000"]
